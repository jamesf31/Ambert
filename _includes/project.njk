---
layout: layout.njk
---

<div class="site">

  <aside class="sidebar">

  <main class="project-page">

    <div class="project-text">

      

      

    </div>

    </aside>

    <div class="project-images">

        <img
            src="{{ project.inputPath | coverImage | url }}"
            alt=""
        >

        {% for image in page.inputPath | previewImages %}

          <img src="{{ image | url }}">

        {% endfor %}

        {% for image in page.inputPath | fullImages %}

            <img src="{{ image | url }}">

        {% endfor %}

    </div>

  </main>

</div>